<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:OnTrack.WPF.Styles">

    <!--Colors-->
    <Color x:Key="PrimaryColor1">#0b0c10</Color>
    <Color x:Key="PrimaryColor2">#1F2833</Color>
    
    <!--Brushes-->
    <SolidColorBrush x:Key="PrimaryBrush1" Color="{StaticResource PrimaryColor1}"/>
    <SolidColorBrush x:Key="PrimaryBrush2" Color="{StaticResource PrimaryColor2}"/>

</ResourceDictionary>